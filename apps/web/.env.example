# Local Postgres started by docker-compose.yml at the repo root.
# Copy to apps/web/.env.local and adjust if you point at a different database.
DATABASE_URL=postgres://cxallies:cxallies_dev@localhost:5434/cxallies

# Better Auth — generate the secret with: `openssl rand -base64 32`
BETTER_AUTH_SECRET=replace-me-with-32-plus-chars-of-randomness
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Owner seed (consumed by `pnpm db:seed`; not needed at runtime).
# Use a strong password — the seed hashes it via Better Auth at insert time.
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=replace-with-12-plus-character-password

# Cloudflare R2 / S3-compatible object storage. For local dev these point at
# the MinIO container in docker-compose.yml. For production, point at R2:
#   R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   R2_ACCESS_KEY_ID + R2_SECRET_ACCESS_KEY from a Cloudflare R2 API token
#   R2_BUCKET=cxallies-prod
R2_ENDPOINT=http://localhost:9000
R2_REGION=auto
R2_ACCESS_KEY_ID=cxallies
R2_SECRET_ACCESS_KEY=cxallies_dev_minio
R2_BUCKET=cxallies-dev

# Postmark transactional email.
#
# For local dev without a Postmark account, set the server token to the
# magic value POSTMARK_API_TEST — Postmark accepts the API call and returns
# a synthetic message ID without sending real email. Useful for verify
# scripts and unit tests.
#
# For real dev (sending to a verified address): create a Postmark Sandbox
# server in your Postmark account and use that server's token.
#
# For prod (P1-26 onward): use the production server token, and verify
# the sender domain (DKIM/SPF/DMARC) before flipping. Sender domain
# verification can take 24-48h to propagate; start DNS records early.
POSTMARK_SERVER_TOKEN=POSTMARK_API_TEST
POSTMARK_FROM_ADDRESS=invoices@example.com
POSTMARK_FROM_NAME=CXAllies
POSTMARK_MESSAGE_STREAM=outbound

# Public-facing base URL used in outbound emails for "view in browser" links.
# Localhost in dev. In prod set to https://app.cxallies.com (or wherever the
# app lives). Misconfiguration here silently breaks email links.
APP_BASE_URL=http://localhost:3000
